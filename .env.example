# App
NODE_ENV=development
PORT=3000

# Database (Phase 1)
DATABASE_URL=postgres://queerpulse:queerpulse@localhost:5432/queerpulse

# Database TLS (secure by default in production; verification ON).
# Applies to BOTH the app and the migration CLI — see src/config/database-ssl.ts.
#
# DATABASE_SSL overrides negotiation explicitly: true | false.
# DATABASE_SSL=false
# DATABASE_SSL_CA=/path/to/ca.pem            # inline PEM or a file path
# DATABASE_SSL_INSECURE=true                 # keep TLS, skip cert verification
#
# MANAGED POSTGRES (Railway, Render, Fly, ...): the default — TLS on with
# verification — will NOT connect, and the app crash-loops with no useful error.
# Pick the line that matches how you reach the database:
#
#   Private network (e.g. postgres.railway.internal): the server speaks
#   plaintext, so TLS must be off. Traffic never leaves the provider's network.
#     DATABASE_SSL=false
#
#   Public proxy / external host: the server presents a self-signed cert, so
#   verification must be relaxed. The channel is still encrypted.
#     DATABASE_SSL_INSECURE=true
#
# Prefer DATABASE_SSL_CA over DATABASE_SSL_INSECURE wherever the provider
# publishes a CA bundle — that keeps verification on.

# Database connection pool / timeouts (pg). Defaults shown.
# DATABASE_POOL_MAX=10
# DATABASE_POOL_MIN=0
# DATABASE_CONNECTION_TIMEOUT_MS=10000
# DATABASE_IDLE_TIMEOUT_MS=30000
# DATABASE_STATEMENT_TIMEOUT_MS=30000

# Frontend origin allowlist. Required when NODE_ENV=production.
#
# Comma-separated list of EXACT origins: scheme + host (+ port), NO path and NO
# trailing slash — this is a strict allowlist matched against the browser's
# `Origin` header, which never carries a trailing slash. It gates both HTTP CORS
# and the socket.io chat handshake. Boot fails if an entry is not an exact origin.
#   good: https://queerpulse.com,https://www.queerpulse.com
#   bad:  https://queerpulse.com/          (trailing slash)
#   bad:  queerpulse.com                   (no scheme)
#
# The FIRST entry is the canonical origin: it is where OAuth sign-in redirects
# land. Additional entries are accepted but never redirected to.
FRONTEND_URL=http://localhost:5173

# Auth — JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Auth — Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Cookies
#
# COOKIE_DOMAIN is the `Domain` attribute of the auth cookies — a bare domain,
# not a URL (no scheme, port or path).
#
# LEAVE THIS UNSET. That is the correct value in production too, not just
# locally. It used to say a leading-dot parent domain was required for the
# frontend-on-queerpulse.com / API-on-api.queerpulse.com topology. That was
# WRONG: the auth cookies are httpOnly, so the SPA never reads them — only the
# API does. A host-only cookie set by api.queerpulse.com is returned to
# api.queerpulse.com on every `credentials: 'include'` fetch, because SameSite
# gates on the registrable domain and those two are same-site. It already works.
#
# Setting COOKIE_DOMAIN=.queerpulse.com instead broadcasts a 30-day refresh
# token to EVERY current and future subdomain — staging, status pages, any
# third-party-hosted CNAME. One XSS or takeover anywhere under the parent leaks
# 30 days of session. Only set this if the frontend ever moves to a host that is
# genuinely not same-site with the API, and weigh that cost first.
#
# Both `COOKIE_DOMAIN=` and omitting the line entirely mean "unset".
#
# Cookies are always SameSite=Lax. That is correct for this same-parent-domain
# topology and is deliberately NOT loosened — do not change it to `None` unless
# the frontend moves to a different registrable domain.
COOKIE_DOMAIN=

# Membership
# How many invites a member may create per calendar month (default 1)
INVITE_MONTHLY_QUOTA=1

# Storage (S3-compatible). REQUIRED when NODE_ENV=production — boot fails
# without S3_BUCKET / S3_ACCESS_KEY / S3_SECRET_KEY, because every upload route
# (avatars included) would otherwise fail per-request at runtime on a server
# that reports itself healthy.
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=                             # optional CDN/base url for fileUrl

# Observability / feature flags (all optional)
# SENTRY_DSN=                                # enables Sentry error reporting when set
# LOG_LEVEL=info                             # pino log level (info, debug, ...)
# LOG_PRETTY=true                            # pino-pretty output; defaults on when
#                                            # NODE_ENV=development. NEVER set this in a
#                                            # deployed environment — pino-pretty is a
#                                            # devDependency and is absent from the
#                                            # production image, so it crashes at boot.
# ENABLE_SWAGGER=true                        # serve the OpenAPI/Swagger UI
