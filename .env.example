# App
NODE_ENV=development
PORT=3000

# Database (Phase 1)
DATABASE_URL=postgres://queerpulse:queerpulse@localhost:5432/queerpulse

# Database TLS (secure by default in production; verification ON).
# DATABASE_SSL overrides negotiation explicitly: true | false.
# DATABASE_SSL=false
# DATABASE_SSL_CA=/path/to/ca.pem            # inline PEM or a file path
# DATABASE_SSL_INSECURE=true                 # disable cert verification (local/self-signed ONLY)

# Database connection pool / timeouts (pg). Defaults shown.
# DATABASE_POOL_MAX=10
# DATABASE_POOL_MIN=0
# DATABASE_CONNECTION_TIMEOUT_MS=10000
# DATABASE_IDLE_TIMEOUT_MS=30000
# DATABASE_STATEMENT_TIMEOUT_MS=30000

# Frontend origin (used from Phase 2 onward; present now so config validates uniformly)
FRONTEND_URL=http://localhost:5173

# Auth — JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Auth — Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Cookies (leave COOKIE_DOMAIN unset for localhost)
COOKIE_DOMAIN=

# Membership
VOUCH_THRESHOLD=2
# How many invites a member may create per calendar month (default 1)
INVITE_MONTHLY_QUOTA=1

# Observability / feature flags (all optional)
# SENTRY_DSN=                                # enables Sentry error reporting when set
# LOG_LEVEL=info                             # pino log level (info, debug, ...)
# ENABLE_SWAGGER=true                        # serve the OpenAPI/Swagger UI
