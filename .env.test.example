# Environment for the e2e suite (`pnpm run test:e2e`).
#
# Copy to `.env.test` and point DATABASE_URL at a THROWAWAY database. The e2e
# suites DELETE every table between tests, so the safety guard
# (test/db-safety.ts) refuses to run unless the database name ends in "_test"
# OR you set TEST_DATABASE_URL explicitly.
#
# `.env.test` overrides values; any variable it omits falls back to `.env`.

NODE_ENV=test
PORT=3000

# Must end in "_test" (or set TEST_DATABASE_URL instead).
DATABASE_URL=postgres://queerpulse:queerpulse@localhost:5432/queerpulse_test

# Alternative to a *_test database name: an explicit, dedicated test URL.
# When set, it becomes the effective DATABASE_URL and bypasses the name check.
# TEST_DATABASE_URL=postgres://queerpulse:queerpulse@localhost:5432/qp_ci

# Any secrets/creds the app validates at boot can be inherited from `.env`,
# or set here to keep the test environment fully self-contained, e.g.:
# JWT_ACCESS_SECRET=test-access-secret
# JWT_REFRESH_SECRET=test-refresh-secret
# GOOGLE_CLIENT_ID=test-client-id
# GOOGLE_CLIENT_SECRET=test-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
