meta {
  name: Delete Connection
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/connections/{{connectionId}}
  body: none
  auth: none
}

headers {
  Content-Type: application/json
  X-CSRF-Token: {{csrfToken}}
}

docs {
  Active-only. Returns { ok: true }. Can't delete a connection the other party blocked you on. Rate limit on POST /connections: 30/min.
}
