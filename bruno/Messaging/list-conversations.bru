meta {
  name: List Conversations
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/conversations
  body: none
  auth: none
}

docs {
  Active-only. Returns ConversationResponse[]: id, type ("dm" | "group"),
  otherParticipant { handle, displayName, avatarUrl }, lastMessage (with its
  own `sender`), unreadCount, updatedAt, plus the backend extras isOfficial
  and muted. Sorted most-recently-active first.
}
