meta {
  name: Presign Avatar
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/uploads/avatar
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-CSRF-Token: {{csrfToken}}
}

body:json {
  "contentType": "image/png"
}

docs {
  Pending-ok. contentType in image/jpeg|png|webp|gif. Returns { uploadUrl, fileUrl }. PUT the bytes to uploadUrl (matching Content-Type), then PATCH /profiles/me { avatarUrl: fileUrl }.
}
