meta {
  name: Presign Work Image
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/uploads/work-image
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-CSRF-Token: {{csrfToken}}
}

body:json {
  "contentType": "image/jpeg"
}

docs {
  Pending-ok. Returns { uploadUrl, fileUrl }. PUT bytes to uploadUrl, then reference fileUrl as imageUrl in a work item.
}
