meta {
  name: Refresh
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/refresh
  body: none
  auth: none
}

headers {
  Content-Type: application/json
  X-CSRF-Token: {{csrfToken}}
}

docs {
  Public. Uses the refresh_token cookie to rotate cookies. Returns { ok: true }. 401 clears cookies (force re-login). Rate limit: 10/min.
}
