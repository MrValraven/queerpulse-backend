meta {
  name: Create Title (admin)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/cinema/titles
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-CSRF-Token: {{csrfToken}}
}

body:json {
  "kind": "film",
  "title": "My Film",
  "description": "Optional synopsis",
  "coverImageUrl": "https://example.com/cover.jpg"
}

docs {
  Moderator/admin. Creates a draft title (kind: film | short).
}
